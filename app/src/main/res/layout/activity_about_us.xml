<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/top_blue_bg"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="About Me"
                android:textSize="32sp"
                android:fontFamily="@font/roboto_bold"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_marginBottom="25dp"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:src="@drawable/profile_pic"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/CircleImage"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aman Kumar Pandit"
                android:textStyle="bold"
                android:textSize="24sp"
                android:fontFamily="@font/gluten_extra_bold"
                android:textColor="@android:color/white"
                android:layout_marginTop="15dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Software Engineer | B.Tech (ICE), NSUT"
                android:textSize="15sp"
                android:textColor="@android:color/white"
                android:layout_marginTop="5dp"/>

        </LinearLayout>

        <!-- ================= About Section ================= -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="15dp"
            app:cardElevation="5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- About -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="@color/blue"
                    android:fontFamily="@font/roboto_bold"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/blue_stroke"
                    android:padding="15dp"
                    android:fontFamily="@font/bai_jamjuree_regular"
                    android:lineSpacingExtra="5dp"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:text="Hello! I'm Aman Kumar Pandit, a fourth-year B.Tech student in Instrumentation and Control Engineering at Netaji Subhas University of Technology (NSUT), Delhi.

I am passionate about Android Development, and solving Data Structures and Algorithms problems. I enjoy building real-world mobile applications using Kotlin, XML, Firebase, and modern Android technologies.

I continuously work on projects that solve practical problems and help me improve my development skills. My goal is to become a skilled Software Engineer capable of building scalable and user-friendly applications."/>

                <!-- Divider -->

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="10dp"
                    android:background="#DDDDDD"/>

                <!-- Connect -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connect With Me"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:fontFamily="@font/roboto_bold"
                    android:textColor="@color/blue"
                    android:layout_marginTop="10dp"/>

                <!-- GitHub -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/github_id"
                    android:layout_width="250dp"
                    android:layout_height="60dp"
                    android:layout_marginTop="15dp"
                    app:cardCornerRadius="13dp"
                    android:layout_gravity="center"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:id="@+id/githubLayout"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:background="@drawable/blue_stroke"
                        android:clickable="true"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/github_img"
                            android:contentDescription="GitHub" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="GitHub"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/black" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/linkedin_id"
                    android:layout_width="250dp"
                    android:layout_height="60dp"
                    android:layout_marginTop="12dp"
                    android:layout_gravity="center"
                    android:clickable="true"
                    app:cardCornerRadius="13dp">

                    <LinearLayout
                        android:id="@+id/linkedinLayout"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:background="@drawable/blue_stroke"
                        android:clickable="true"
                        android:gravity="center"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/linkedin_img" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="LinkedIn"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/instagram_id"
                    android:layout_width="250dp"
                    android:layout_height="60dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="60dp"
                    android:layout_gravity="center"
                    android:clickable="true"
                    app:cardCornerRadius="13dp">

                    <LinearLayout
                        android:id="@+id/instagramLayout"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:background="@drawable/blue_stroke"
                        android:clickable="true"
                        android:gravity="center"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/instagram_img" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_gravity="center"
                            android:text="Instagram"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>